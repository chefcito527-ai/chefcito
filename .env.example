# Copia este archivo como .env y completa tus claves reales

# Neon PostgreSQL — copia la "Connection string" desde console.neon.tech
# Tu proyecto → Dashboard → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require

# Flask — clave secreta para las sesiones (genera una aleatoria segura)
SECRET_KEY=COLOCA_UNA_CLAVE_SECRETA_ALEATORIA
